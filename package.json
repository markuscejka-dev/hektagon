  .live-label { font-size:11px; color:var(--gd); display:flex; align-items:center; gap:6px; }

  /* KPI GRID */
  .kpi-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:14px; margin-bottom:24px; }
  @media(max-width:900px) { .kpi-grid{grid-template-columns:repeat(2,1fr);} }
  .kpi-card { background:var(--glass); border:1px solid var(--gb); border-radius:var(--rad); padding:22px 20px; backdrop-filter:var(--blur); transition:border-color 0.2s; }
  .kpi-card:hover { border-color:var(--gb2); }
