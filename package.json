  .kpi-value { font-family:var(--fd); font-weight:800; font-size:32px; letter-spacing:-1.5px; line-height:1; margin-bottom:8px; }
  .kpi-delta { font-size:12px; display:flex; align-items:center; gap:4px; }
  .kpi-delta.up { color:var(--g); }
  .kpi-delta.down { color:var(--r); }
  .kpi-delta.neu { color:var(--w30); }

  /* GRID 2COL */
  .grid2 { display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:24px; }
  @media(max-width:900px) { .grid2{grid-template-columns:1fr;} }
  .grid3 { display:grid; grid-template-columns:2fr 1fr; gap:14px; margin-bottom:24px; }
  @media(max-width:900px) { .grid3{grid-template-columns:1fr;} }

  /* CARD */
  .card { background:var(--glass); border:1px solid var(--gb); border-radius:var(--rad); padding:24px; backdrop-filter:var(--blur); }
  .card-title { font-family:var(--fd); font-weight:700; font-size:14px; letter-spacing:-0.3px; margin-bottom:20px; display:flex; align-items:center; justify-content:space-between; }
  .card-badge { font-size:10px; font-weight:600; letter-spacing:0.5px; padding:3px 8px; border-radius:20px; }
  .badge-g { background:var(--gg); color:var(--gd); border:1px solid rgba(48,215,128,0.2); }
  .badge-b { background:var(--bg_); color:var(--b); border:1px solid rgba(10,132,255,0.2); }

  /* CHART BAR */
  .bar-chart { display:flex; align-items:flex-end; gap:3px; height:80px; }
  .bar-col { flex:1; display:flex; flex-direction:column; align-items:center; gap:4px; }
  .bar { width:100%; border-radius:3px 3px 0 0; transition:opacity 0.2s; cursor:pointer; min-height:2px; }
  .bar:hover { opacity:0.8; }
  .bar-label { font-size:9px; color:var(--w30); }

  /* COUNTRY TABLE */
  .ctable { width:100%; border-collapse:collapse; }
  .ctable th { font-size:10px; font-weight:700; letter-spacing:1px; text-transform:uppercase; color:var(--w30); padding:0 0 12px; text-align:left; border-bottom:1px solid var(--gb); }
  .ctable th:last-child { text-align:right; }
  .ctable td { padding:13px 0; border-bottom:1px solid var(--gb); font-size:13px; vertical-align:middle; }
  .ctable tr:last-child td { border-bottom:none; }
  .ctable td:last-child { text-align:right; }
  .country-row-flag { font-size:18px; margin-right:8px; }
  .country-row-name { font-weight:500; }
  .progress-wrap { display:flex; align-items:center; gap:8px; }
  .progress-bar { flex:1; height:4px; background:var(--w05); border-radius:2px; overflow:hidden; }
  .progress-fill { height:100%; border-radius:2px; }
  .conv-pill { font-size:11px; font-weight:600; padding:2px 8px; border-radius:20px; background:var(--gg); color:var(--gd); }

  /* PLAN DONUT (CSS only) */
  .donut-wrap { display:flex; align-items:center; gap:24px; }
  .donut { width:80px; height:80px; border-radius:50%; position:relative; flex-shrink:0; }
  .donut-legend { display:flex; flex-direction:column; gap:8px; }
  .dl-item { display:flex; align-items:center; gap:8px; font-size:13px; }
  .dl-dot { width:8px; height:8px; border-radius:50%; flex-shrink:0; }
  .dl-num { font-family:var(--fd); font-weight:700; font-size:15px; margin-left:auto; }

  /* LANG BARS */
  .lang-row { display:flex; align-items:center; gap:10px; margin-bottom:12px; }
  .lang-row:last-child { margin-bottom:0; }
  .lang-name { font-size:13px; width:52px; flex-shrink:0; }
  .lang-bar-wrap { flex:1; height:6px; background:var(--w05); border-radius:3px; overflow:hidden; }
  .lang-bar-fill { height:100%; background:var(--g); border-radius:3px; transition:width 1s ease; }
  .lang-pct { font-size:12px; color:var(--w60); width:36px; text-align:right; flex-shrink:0; font-family:var(--fd); font-weight:600; }

  /* RECENT TABLE */
  .rtable { width:100%; border-collapse:collapse; }
  .rtable th { font-size:10px; font-weight:700; letter-spacing:1px; text-transform:uppercase; color:var(--w30); padding:0 0 12px; text-align:left; border-bottom:1px solid var(--gb); }
  .rtable td { padding:12px 0; border-bottom:1px solid var(--gb); font-size:13px; }
  .rtable tr:last-child td { border-bottom:none; }
