  .login-btn { width:100%; background:var(--g); color:#000; border:none; border-radius:var(--rads); padding:13px; font-family:var(--fd); font-weight:700; font-size:14px; cursor:pointer; transition:all 0.18s; }
  .login-btn:hover { background:#3eea8c; }
