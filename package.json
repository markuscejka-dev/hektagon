  .uid { font-family:monospace; font-size:11px; color:var(--w30); }

  /* MRR SPLIT */
  .rev-split { display:flex; gap:0; border:1px solid var(--gb); border-radius:var(--rads); overflow:hidden; margin-bottom:20px; }
  .rev-part { flex:1; padding:14px 16px; text-align:center; }
  .rev-part + .rev-part { border-left:1px solid var(--gb); }
  .rev-part-val { font-family:var(--fd); font-weight:700; font-size:22px; letter-spacing:-1px; }
  .rev-part-label { font-size:11px; color:var(--w30); margin-top:3px; }

  /* SUPABASE HINT */
  .supabase-hint { background:rgba(10,132,255,0.06); border:1px solid rgba(10,132,255,0.18); border-radius:var(--rads); padding:14px 18px; font-size:12px; color:rgba(10,132,255,0.8); margin-bottom:24px; display:flex; align-items:flex-start; gap:10px; line-height:1.6; }

  /* SCROLL */
  ::-webkit-scrollbar { width:4px; } ::-webkit-scrollbar-track { background:transparent; } ::-webkit-scrollbar-thumb { background:var(--gb2); border-radius:2px; }
`;

const NAV_ITEMS = [
  { id:"overview", label:"Übersicht", icon:"📊" },
  { id:"users",    label:"Nutzer",    icon:"👤" },
  { id:"revenue",  label:"Revenue",   icon:"💰" },
  { id:"geo",      label:"Länder",    icon:"🌍" },
];

export default function AdminDash() {
  const [auth, setAuth] = useState(false);
  const [pw, setPw] = useState("");
  const [pwErr, setPwErr] = useState(false);
  const [nav, setNav] = useState("overview");
  const [period, setPeriod] = useState("30 Tage");
  const [animated, setAnimated] = useState(false);

  useEffect(() => {
    if (auth) setTimeout(() => setAnimated(true), 100);
  }, [auth]);

  const login = () => {
    if (pw === ADMIN_PASS) { setAuth(true); setPwErr(false); }
    else setPwErr(true);
  };

  if (!auth) return (
    <>
      <style>{css}</style>
      <div className="login">
        <div className="login-card">
          <div className="login-logo">N</div>
          <div className="login-title">Admin Dashboard</div>
          <div className="login-sub">Nebenkostencheck · Interner Zugang</div>
          <input className="login-input" type="password" placeholder="Passwort" value={pw}
            onChange={e=>setPw(e.target.value)} onKeyDown={e=>e.key==="Enter"&&login()} autoFocus />
          <button className="login-btn" onClick={login}>Einloggen</button>
          {pwErr && <div className="login-err">Falsches Passwort</div>}
          <div style={{fontSize:11,color:"var(--w30)",marginTop:16}}>Demo-Passwort: hektagon2024</div>
        </div>
      </div>
    </>
  );

  const d = DEMO;
  const totalPct = (v, t) => Math.round(v / t * 100);

  // Bar chart heights
  const maxSignup = Math.max(...d.dailySignups);
  const maxRev = Math.max(...d.dailyRevenue);

  return (
    <>
      <style>{css}</style>
      <div className="dash">

        {/* SIDEBAR */}
        <div className="sidebar">
          <div className="sb-logo">
            <div className="sb-lm">N</div>
            <div>
              <div>Nebenkostencheck</div>
              <div className="sb-admin">Admin</div>
            </div>
          </div>
          <div className="sb-section">Navigation</div>
          {NAV_ITEMS.map(n => (
            <div key={n.id} className={`sb-item${nav===n.id?" active":""}`} onClick={()=>setNav(n.id)}>
              <span className="sb-icon">{n.icon}</span>{n.label}
            </div>
          ))}
          <div className="sb-section">System</div>
          <div className="sb-item"><span className="sb-icon">⚙️</span>Einstellungen</div>
          <div className="sb-item"><span className="sb-icon">🔗</span>Stripe Dashboard</div>
          <div className="sb-bottom">
            <div className="sb-logout" onClick={()=>setAuth(false)}>← Ausloggen</div>
          </div>
        </div>

        {/* MAIN CONTENT */}
        <div className="main">
          <div className="topbar">
            <div>
              <div className="page-title">
                {nav==="overview"?"Übersicht":nav==="users"?"Nutzer":nav==="revenue"?"Revenue":"Länder"}
              </div>
              <div className="page-sub">Nebenkostencheck · Live Daten</div>
            </div>
            <div className="topbar-right">
              <div className="live-label"><div className="live-dot"/>Live</div>
              {["7 Tage","30 Tage","90 Tage","Gesamt"].map(p=>(
                <div key={p} className="period-sel" style={period===p?{borderColor:"var(--g)",color:"var(--g)"}:{}} onClick={()=>setPeriod(p)}>{p}</div>
              ))}
            </div>
          </div>

          {/* Supabase hint */}
          <div className="supabase-hint">
            🔗 <span><strong>Demo-Daten.</strong> Verbinde Supabase um echte Nutzerdaten zu sehen: <code>supabase.from('users').select('*')</code> — Setup-Anleitung auf Anfrage.</span>
          </div>

          {/* ── OVERVIEW ── */}
          {nav === "overview" && <>
            <div className="kpi-grid">
              {[
                { label:"Gesamt-Nutzer",   value:d.totalUsers.toLocaleString("de"),   delta:d.totalUsersDelta,    suffix:"",   up:true  },
                { label:"Zahlende Nutzer", value:d.payingUsers.toLocaleString("de"),  delta:d.payingUsersDelta,   suffix:"",   up:true  },
                { label:"MRR",             value:`€${d.mrr.toLocaleString("de")}`,     delta:d.mrrDelta,           suffix:"",   up:true  },
                { label:"Conversion",      value:`${d.conversionRate}%`,               delta:d.conversionDelta,    suffix:"",   up:true  },
              ].map((k,i)=>(
                <div className="kpi-card" key={i}>
                  <div className="kpi-label">{k.label}</div>
                  <div className="kpi-value">{k.value}</div>
                  <div className={`kpi-delta ${k.up?"up":"down"}`}>
                    {k.up?"↑":"↓"} {Math.abs(k.delta)}% vs. Vorperiode
                  </div>
                </div>
              ))}
            </div>

            <div className="grid3">
              {/* Daily Signups Chart */}
              <div className="card">
                <div className="card-title">
                  Neue Nutzer (letzte 30 Tage)
                  <span className="card-badge badge-g">+{d.dailySignups.slice(-7).reduce((a,b)=>a+b,0)} diese Woche</span>
                </div>
                <div className="bar-chart">
                  {d.dailySignups.map((v,i)=>(
                    <div className="bar-col" key={i} title={`Tag ${i+1}: ${v} Signups`}>
                      <div className="bar" style={{ height:`${(v/maxSignup)*100}%`, background:`rgba(48,215,128,${0.3 + (v/maxSignup)*0.7})` }} />
                    </div>
                  ))}
                </div>
                <div style={{display:"flex",justifyContent:"space-between",marginTop:8,fontSize:10,color:"var(--w30)"}}>
                  <span>Vor 30 Tagen</span><span>Heute</span>
                </div>
              </div>

              {/* Plan Split */}
              <div className="card">
                <div className="card-title">Plan-Verteilung</div>
                <div className="donut-wrap">
                  <div className="donut" style={{
                    background: `conic-gradient(var(--g) 0% ${totalPct(d.planPro, d.payingUsers)}%, rgba(255,255,255,0.12) ${totalPct(d.planPro, d.payingUsers)}% 100%)`
                  }} />
                  <div className="donut-legend">
                    <div className="dl-item">
                      <div className="dl-dot" style={{background:"var(--g)"}}/>
                      <span style={{fontSize:12,color:"var(--w60)"}}>Pro Jahres</span>
                      <span className="dl-num">{d.planPro}</span>
                    </div>
                    <div className="dl-item">
                      <div className="dl-dot" style={{background:"rgba(255,255,255,0.18)"}}/>
                      <span style={{fontSize:12,color:"var(--w60)"}}>Basis Einmalig</span>
                      <span className="dl-num">{d.planOnce}</span>
                    </div>
                    <div style={{height:1,background:"var(--gb)",margin:"6px 0"}}/>
                    <div className="dl-item">
                      <span style={{fontSize:11,color:"var(--w30)"}}>Pro-Rate</span>
                      <span className="dl-num" style={{color:"var(--g)",fontSize:13}}>{totalPct(d.planPro,d.payingUsers)}%</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            {/* Recent Signups */}
            <div className="card">
              <div className="card-title">Letzte Zahlungen <span className="card-badge badge-g">Live</span></div>
              <table className="rtable">
                <thead>
                  <tr>
                    <th>User ID</th><th>Land</th><th>Sprache</th><th>Plan</th><th>Zeit</th><th style={{textAlign:"right"}}>Betrag</th>
                  </tr>
                </thead>
                <tbody>
                  {d.recentUsers.map((u,i)=>(
                    <tr key={i}>
                      <td><span className="uid">{u.id}</span></td>
                      <td>{u.country}</td>
                      <td><span style={{fontSize:12,color:"var(--w60)"}}>{u.lang}</span></td>
                      <td><span className={`plan-tag ${u.plan==="Pro"?"plan-pro":"plan-once"}`}>{u.plan}</span></td>
                      <td style={{color:"var(--w30)",fontSize:12}}>{u.date}</td>
                      <td style={{textAlign:"right",fontFamily:"var(--fd)",fontWeight:600,color:"var(--g)"}}>{u.amount}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </>}

          {/* ── USERS ── */}
          {nav === "users" && <>
            <div className="kpi-grid">
              {[
                { label:"Gesamt",        value:d.totalUsers.toLocaleString("de"),  delta:"+12.4%", up:true  },
                { label:"Zahlen gerade", value:d.payingUsers.toLocaleString("de"), delta:"+8.1%",  up:true  },
                { label:"Churn Rate",    value:`${d.churnRate}%`,                  delta:"-0.4%",  up:true  },
                { label:"Ø Checks/User", value:d.avgCheckPerUser,                  delta:"+0.2",   up:true  },
              ].map((k,i)=>(
                <div className="kpi-card" key={i}>
                  <div className="kpi-label">{k.label}</div>
                  <div className="kpi-value">{k.value}</div>
                  <div className={`kpi-delta ${k.up?"up":"down"}`}>{k.delta} vs. Vormonat</div>
                </div>
              ))}
            </div>

            <div className="grid2">
              <div className="card">
                <div className="card-title">Sprachen der Nutzer</div>
                {d.languages.map((l,i)=>(
                  <div className="lang-row" key={i}>
                    <div className="lang-name">{l.lang}</div>
                    <div className="lang-bar-wrap">
                      <div className="lang-bar-fill" style={{width: animated ? `${l.pct}%`:"0%"}}/>
                    </div>
                    <div className="lang-pct">{l.pct}%</div>
                  </div>
                ))}
              </div>

              <div className="card">
                <div className="card-title">Conversion by Country</div>
                <table className="ctable">
                  <thead><tr><th>Land</th><th>Nutzer</th><th>Conv.</th></tr></thead>
                  <tbody>
                    {d.countries.map((c,i)=>(
                      <tr key={i}>
                        <td><span className="country-row-flag">{c.flag}</span><span className="country-row-name">{c.code}</span></td>
                        <td style={{color:"var(--w60)"}}>{c.users.toLocaleString("de")}</td>
                        <td><span className="conv-pill">{totalPct(c.paying,c.users)}%</span></td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>

            <div className="card">
              <div className="card-title">Alle neuesten Nutzer</div>
              <table className="rtable">
                <thead><tr><th>User ID</th><th>Land</th><th>Sprache</th><th>Plan</th><th>Zeit</th><th style={{textAlign:"right"}}>Betrag</th></tr></thead>
                <tbody>
                  {d.recentUsers.map((u,i)=>(
                    <tr key={i}>
                      <td><span className="uid">{u.id}</span></td>
                      <td>{u.country}</td>
                      <td><span style={{fontSize:12,color:"var(--w60)"}}>{u.lang}</span></td>
                      <td><span className={`plan-tag ${u.plan==="Pro"?"plan-pro":"plan-once"}`}>{u.plan}</span></td>
                      <td style={{color:"var(--w30)",fontSize:12}}>{u.date}</td>
                      <td style={{textAlign:"right",fontFamily:"var(--fd)",fontWeight:600,color:"var(--g)"}}>{u.amount}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </>}

          {/* ── REVENUE ── */}
          {nav === "revenue" && <>
            <div className="kpi-grid">
              {[
                { label:"MRR",          value:`€${d.mrr.toLocaleString("de")}`,  delta:"+15.2%", up:true },
                { label:"ARR (Prognose)", value:`€${(d.mrr*12).toLocaleString("de")}`, delta:"",  up:true },
                { label:"ARPU",         value:`€${(d.mrr/d.payingUsers).toFixed(2)}`, delta:"+3.1%", up:true },
                { label:"LTV (Ø 18 Mo)", value:`€${(d.mrr/d.payingUsers*18).toFixed(0)}`, delta:"", up:true },
              ].map((k,i)=>(
                <div className="kpi-card" key={i}>
                  <div className="kpi-label">{k.label}</div>
                  <div className="kpi-value">{k.value}</div>
                  {k.delta && <div className="kpi-delta up">↑ {k.delta} vs. Vormonat</div>}
                </div>
              ))}
            </div>

            <div className="grid3">
              <div className="card">
                <div className="card-title">
                  Tages-Revenue (letzte 30 Tage)
                  <span className="card-badge badge-g">€{d.dailyRevenue.slice(-7).reduce((a,b)=>a+b,0)} diese Woche</span>
                </div>
                <div className="bar-chart">
                  {d.dailyRevenue.map((v,i)=>(
                    <div className="bar-col" key={i} title={`Tag ${i+1}: €${v}`}>
                      <div className="bar" style={{height:`${(v/maxRev)*100}%`,background:`rgba(48,215,128,${0.25+(v/maxRev)*0.75})`}}/>
                    </div>
                  ))}
                </div>
                <div style={{display:"flex",justifyContent:"space-between",marginTop:8,fontSize:10,color:"var(--w30)"}}>
                  <span>Vor 30 Tagen</span><span>Heute</span>
                </div>
              </div>

              <div className="card">
                <div className="card-title">Revenue Split</div>
                <div className="rev-split">
                  <div className="rev-part">
                    <div className="rev-part-val" style={{color:"var(--g)"}}>€{d.revPro.toLocaleString("de")}</div>
                    <div className="rev-part-label">Pro Abo</div>
                  </div>
                  <div className="rev-part">
                    <div className="rev-part-val">€{d.revOnce.toLocaleString("de")}</div>
                    <div className="rev-part-label">Einmalig</div>
                  </div>
                </div>
                <div style={{fontSize:12,color:"var(--w30)",lineHeight:1.7}}>
                  <div style={{display:"flex",justifyContent:"space-between",paddingBottom:8,borderBottom:"1px solid var(--gb)",marginBottom:8}}>
                    <span>Pro-Anteil am Revenue</span>
                    <span style={{color:"var(--g)",fontWeight:600}}>{totalPct(d.revPro, d.mrr)}%</span>
                  </div>
                  <div style={{display:"flex",justifyContent:"space-between",paddingBottom:8,borderBottom:"1px solid var(--gb)",marginBottom:8}}>
                    <span>Ø Zahlung</span>
                    <span style={{fontWeight:600}}>€{(d.mrr/d.payingUsers).toFixed(2)}</span>
                  </div>
                  <div style={{display:"flex",justifyContent:"space-between"}}>
                    <span>Stripe Gebühren (~2.9%)</span>
                    <span style={{color:"var(--r)"}}>–€{Math.round(d.mrr*0.029)}</span>
                  </div>
                </div>
              </div>
            </div>
          </>}

          {/* ── GEO ── */}
          {nav === "geo" && <>
            <div className="kpi-grid">
              {d.countries.map((c,i)=>(
                <div className="kpi-card" key={i}>
                  <div className="kpi-label">{c.flag} {c.name}</div>
                  <div className="kpi-value">{c.users.toLocaleString("de")}</div>
                  <div className="kpi-delta up">↑ {c.paying} zahlend · €{c.revenue.toLocaleString("de")} MRR</div>
                </div>
              ))}
              <div className="kpi-card">
                <div className="kpi-label">🌍 DACH Gesamt</div>
                <div className="kpi-value">{d.totalUsers.toLocaleString("de")}</div>
                <div className="kpi-delta up">↑ {d.payingUsers} zahlend</div>
              </div>
            </div>

            <div className="card">
              <div className="card-title">Länder-Breakdown</div>
              <table className="ctable">
                <thead>
                  <tr>
                    <th>Land</th>
                    <th>Nutzer</th>
                    <th>Zahlend</th>
                    <th>Conversion</th>
                    <th>Anteil Nutzer</th>
                    <th style={{textAlign:"right"}}>MRR</th>
                  </tr>
                </thead>
                <tbody>
                  {d.countries.map((c,i)=>(
                    <tr key={i}>
                      <td><span className="country-row-flag">{c.flag}</span><span className="country-row-name">{c.name}</span></td>
                      <td style={{color:"var(--w60)"}}>{c.users.toLocaleString("de")}</td>
                      <td style={{color:"var(--w60)"}}>{c.paying.toLocaleString("de")}</td>
                      <td><span className="conv-pill">{totalPct(c.paying,c.users)}%</span></td>
                      <td style={{minWidth:140}}>
                        <div className="progress-wrap">
                          <div className="progress-bar">
                            <div className="progress-fill" style={{width:`${totalPct(c.users,d.totalUsers)}%`,background:c.color}}/>
                          </div>
                          <span style={{fontSize:11,color:"var(--w30)",width:32,textAlign:"right"}}>{totalPct(c.users,d.totalUsers)}%</span>
                        </div>
                      </td>
                      <td style={{textAlign:"right",fontFamily:"var(--fd)",fontWeight:700,color:"var(--g)"}}>€{c.revenue.toLocaleString("de")}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>

            <div className="grid2">
              <div className="card">
                <div className="card-title">Sprachen nach Land</div>
                {d.countries.map((c,i)=>(
                  <div key={i} style={{marginBottom:i<d.countries.length-1?20:0}}>
                    <div style={{fontSize:12,color:"var(--w60)",fontWeight:600,marginBottom:10}}>{c.flag} {c.name}</div>
                    <div className="lang-row">
                      <div className="lang-name" style={{fontSize:12}}>🇩🇪 DE</div>
                      <div className="lang-bar-wrap"><div className="lang-bar-fill" style={{width:animated?(c.code==="CH"?"72%":"82%"):"0%",background:c.color}}/></div>
                      <div className="lang-pct">{c.code==="CH"?"72%":"82%"}</div>
                    </div>
                    {c.code==="DE"&&<div className="lang-row">
                      <div className="lang-name" style={{fontSize:12}}>🇹🇷 TR</div>
                      <div className="lang-bar-wrap"><div className="lang-bar-fill" style={{width:animated?"18%":"0%",background:c.color}}/></div>
                      <div className="lang-pct">18%</div>
                    </div>}
                    {c.code==="CH"&&<div className="lang-row">
                      <div className="lang-name" style={{fontSize:12}}>🇫🇷 FR</div>
                      <div className="lang-bar-wrap"><div className="lang-bar-fill" style={{width:animated?"18%":"0%",background:c.color}}/></div>
                      <div className="lang-pct">18%</div>
                    </div>}
                  </div>
                ))}
              </div>

              <div className="card">
                <div className="card-title">Top-Insight 💡</div>
                <div style={{display:"flex",flexDirection:"column",gap:14}}>
                  {[
                    { icon:"🇦🇹", text:"Österreich hat die höchste Conversion (28%) — evtl. weniger Konkurrenz", color:"var(--g)" },
                    { icon:"🇹🇷", text:"18% der DE-Nutzer nutzen Türkisch — stärkstes nicht-DE Segment", color:"var(--b)" },
                    { icon:"🇨🇭", text:"Schweiz hat höchsten Ø-Revenue durch CHF-Preise möglich", color:"var(--y)" },
                    { icon:"📈", text:"Pro-Rate steigt: 59% aller zahlenden Nutzer wählen Pro", color:"var(--g)" },
                  ].map((tip,i)=>(
                    <div key={i} style={{display:"flex",gap:12,padding:"12px 14px",background:"var(--w05)",borderRadius:var(--rads)||10,border:"1px solid var(--gb)"}}>
                      <span style={{fontSize:18}}>{tip.icon}</span>
                      <span style={{fontSize:12,color:"var(--w60)",lineHeight:1.5}}>{tip.text}</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </>}

        </div>
      </div>
    </>
  );
}
