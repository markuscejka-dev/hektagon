  /* LAYOUT */
  .dash { display:flex; min-height:100vh; }

  /* SIDEBAR */
  .sidebar { width:220px; flex-shrink:0; background:var(--bg2); border-right:1px solid var(--gb); padding:20px 0; display:flex; flex-direction:column; position:fixed; top:0; bottom:0; left:0; }
